{
  "id": "claude-code",
  "name": "Claude Code",
  "paths": {
    "skills": {
      "project": ".claude/commands",
      "user": "~/.claude/commands"
    },
    "agents": {
      "project": ".claude/agents",
      "user": "~/.claude/agents"
    }
  },
  "variables": {
    "arguments": "$ARGUMENTS"
  },
  "invocation": {
    "skills": "/project/{skill-id}",
    "agents": "/project/{agent-id}"
  }
}